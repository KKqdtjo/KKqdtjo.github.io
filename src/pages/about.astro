---
import SkillTags from '../components/SkillTags.astro';
import Layout from '../layouts/PageLayout.astro';
import { EMAIL, GITHUB_URL, SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
---

<Layout title={`关于 ${SITE_AUTHOR}`} description={SITE_DESCRIPTION}>
	<p>{SITE_DESCRIPTION}</p>

	<h2 id="about-skills">技术栈</h2>
	<SkillTags />

	<p>
		我目前就读于中国人民大学计算机系。欢迎通过 <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
		或
		<a href={`mailto:${EMAIL}`}>邮箱</a>
		与我联系。
	</p>

	<p>
		完整简历请见
		<a href="/CV.pdf" target="_blank" rel="noopener noreferrer">PDF简历</a>
		。
	</p>
</Layout>
