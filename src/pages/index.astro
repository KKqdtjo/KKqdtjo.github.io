---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ProjectCards from '../components/ProjectCards.astro';
import SkillTags from '../components/SkillTags.astro';
import {
	EMAIL,
	GITHUB_URL,
	PROFILE_IMAGE_URL,
	PROFILE_TAGLINE,
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" aria-label="简介">
				<img
					class="hero-avatar"
					src={PROFILE_IMAGE_URL}
					width="120"
					height="120"
					alt={`${SITE_AUTHOR} 的头像`}
					loading="eager"
				/>
				<div class="hero-text">
					<h1>{SITE_AUTHOR}</h1>
					<p class="hero-tagline">{PROFILE_TAGLINE}</p>
					<p class="hero-intro">{SITE_DESCRIPTION}</p>
					<div class="hero-actions">
						<a
							class="hero-link hero-link-secondary"
							href={GITHUB_URL}
							target="_blank"
							rel="noopener noreferrer"
						>
							<svg
								class="hero-link-icon"
								viewBox="0 0 16 16"
								aria-hidden="true"
								width="18"
								height="18"
								><path
									fill="currentColor"
									d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
								></path></svg
							>
							<span>GitHub</span>
						</a>
						<a class="hero-link hero-link-secondary" href={`mailto:${EMAIL}`}>
							<svg
								class="hero-link-icon"
								viewBox="0 0 16 16"
								aria-hidden="true"
								width="18"
								height="18"
								><path
									fill="currentColor"
									d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A2 2 0 0 0 2 12h12a2 2 0 0 0 1.967-1.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"
								></path></svg
							>
							<span>邮箱</span>
						</a>
						<a
							class="hero-btn-primary"
							href="/CV.pdf"
							target="_blank"
							rel="noopener noreferrer"
						>
							简历 (PDF)
						</a>
					</div>
				</div>
			</section>

			<section class="skills" aria-labelledby="skills-heading">
				<h2 id="skills-heading">技术栈</h2>
				<SkillTags />
			</section>

			<section class="projects" aria-labelledby="projects-heading">
				<h2 id="projects-heading">精选项目</h2>
				<ProjectCards />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 1.5rem;
		margin-bottom: 2.5rem;
	}
	.hero-avatar {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		box-shadow: var(--box-shadow);
	}
	.hero-text {
		flex: 1;
		min-width: min(100%, 280px);
	}
	.hero h1 {
		margin-bottom: 0.25rem;
	}
	.hero-tagline {
		margin: 0 0 0.75rem 0;
		color: rgb(var(--gray));
		font-size: 1.1em;
	}
	.hero-intro {
		margin-bottom: 0.85rem;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem 1rem;
		margin: 0;
		font-size: 0.95em;
	}
	.hero-link {
		text-decoration: none;
	}
	.hero-link-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.45em 0.85em;
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 85%);
		border: 1px solid rgba(var(--gray), 22%);
		border-radius: 8px;
		font-weight: 500;
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			color 0.15s ease;
	}
	.hero-link-secondary:hover {
		color: rgb(var(--black));
		background: #fff;
		border-color: rgba(var(--gray), 35%);
	}
	.hero-link-secondary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.hero-link-icon {
		flex-shrink: 0;
		display: block;
	}
	.hero-btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.55em 1.35em;
		font-weight: 600;
		font-size: 1em;
		line-height: 1.35;
		color: #fff;
		background: rgb(var(--black));
		border: none;
		border-radius: 9px;
		text-decoration: none;
		box-shadow: 0 1px 2px rgba(var(--black), 15%);
		transition:
			background 0.15s ease,
			box-shadow 0.15s ease,
			transform 0.15s ease;
	}
	.hero-btn-primary:hover {
		color: #fff;
		background: rgb(var(--gray-dark));
		box-shadow: 0 2px 8px rgba(var(--black), 18%);
	}
	.hero-btn-primary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.hero-btn-primary:active {
		transform: translateY(1px);
	}
	.skills,
	.projects {
		margin-bottom: 2rem;
	}
	@media (max-width: 720px) {
		.hero {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.hero-text {
			text-align: center;
		}
		.hero-actions {
			justify-content: center;
		}
	}
</style>
