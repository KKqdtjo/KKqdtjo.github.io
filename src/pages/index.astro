---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ProjectCards from '../components/ProjectCards.astro';
import {
	EMAIL,
	GITHUB_URL,
	PROFILE_IMAGE_URL,
	PROFILE_STATUS_TAG,
	PROFILE_TAGLINE,
	SITE_AUTHOR,
	SITE_AUTHOR_ZH,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- ── Hero ────────────────────────────────────────────── -->
			<section class="flex flex-col sm:flex-row gap-8 sm:gap-10 items-start mb-12" aria-label="About">
				<!-- Photo -->
				<div class="flex-shrink-0 mx-auto sm:mx-0">
					<img
						src={PROFILE_IMAGE_URL}
						alt={`${SITE_AUTHOR} profile photo`}
						width="160"
						height="160"
						loading="eager"
						class="w-36 h-36 sm:w-40 sm:h-40 rounded-2xl object-cover shadow-md ring-1 ring-gray-200"
					/>
				</div>

				<!-- Text -->
				<div class="flex-1 min-w-0 text-center sm:text-left">
					<!-- Name -->
					<h1 class="text-4xl font-bold tracking-tight text-gray-900 mb-1">
						{SITE_AUTHOR}
						<span class="ml-2 text-2xl font-normal text-gray-400">({SITE_AUTHOR_ZH})</span>
					</h1>

					<!-- Subtitle -->
					<p class="text-base text-gray-500 mb-4">{PROFILE_TAGLINE}</p>

					<!-- Status Tag -->
					<div class="inline-flex items-start gap-2 bg-green-50 text-green-700 text-sm font-medium px-3.5 py-2 rounded-full border border-green-200 mb-4 text-left">
						<span class="mt-0.5 w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></span>
						<span>{PROFILE_STATUS_TAG}</span>
					</div>

					<!-- Bio -->
					<p class="text-base text-gray-700 leading-relaxed mb-4">{SITE_DESCRIPTION}</p>

					<!-- Highlight stats -->
					<div class="flex flex-wrap justify-center sm:justify-start gap-2 mb-5">
						<span class="inline-flex text-xs font-semibold text-gray-500 bg-gray-100 px-2.5 py-1 rounded-full border border-gray-200">GPA 3.77 / 4.0</span>
						<span class="inline-flex text-xs font-semibold text-gray-500 bg-gray-100 px-2.5 py-1 rounded-full border border-gray-200">MCM Meritorious Winner</span>
						<span class="inline-flex text-xs font-semibold text-gray-500 bg-gray-100 px-2.5 py-1 rounded-full border border-gray-200">4 Open Source Projects</span>
					</div>

					<!-- Action links -->
					<div class="flex flex-wrap justify-center sm:justify-start gap-3">
						<!-- GitHub -->
						<a
							href={GITHUB_URL}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 border border-gray-200 px-3.5 py-1.5 rounded-lg transition-colors no-underline"
						>
							<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16" class="flex-shrink-0">
								<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
							</svg>
							GitHub
						</a>

						<!-- Email -->
						<a
							href={`mailto:${EMAIL}`}
							class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 border border-gray-200 px-3.5 py-1.5 rounded-lg transition-colors no-underline"
						>
							<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16" class="flex-shrink-0">
								<path fill="currentColor" d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A2 2 0 0 0 2 12h12a2 2 0 0 0 1.967-1.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"></path>
							</svg>
							Email
						</a>

						<!-- Resume (Primary) -->
						<a
							href="/CV.pdf"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 text-sm font-semibold text-white bg-gray-900 hover:bg-gray-700 px-4 py-1.5 rounded-lg transition-colors no-underline active:translate-y-px"
						>
							<svg viewBox="0 0 16 16" aria-hidden="true" width="15" height="15" class="flex-shrink-0">
								<path fill="currentColor" d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"></path>
								<path fill="currentColor" d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"></path>
							</svg>
							Resume (PDF)
						</a>
					</div>
				</div>
			</section>

			<!-- ── Education ──────────────────────────────────────── -->
			<section class="mb-12" aria-labelledby="education-heading">
				<h2 id="education-heading" class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">
					Education
				</h2>

				<div class="relative pl-6">
					<!-- Timeline vertical line -->
					<div class="absolute left-1.5 top-2 bottom-2 w-px bg-gray-200"></div>
					<!-- Timeline dot -->
					<div class="absolute left-0 top-1.5 w-3 h-3 rounded-full bg-white ring-2 ring-gray-400"></div>

					<div>
						<!-- School + location / dates -->
						<div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-1">
							<span class="text-base font-bold text-gray-900">
								Renmin University of China (RUC)
							</span>
							<span class="text-sm text-gray-400 flex-shrink-0">
								Beijing, China &nbsp;·&nbsp; Sept. 2023 – Present (Expected Jun. 2027)
							</span>
						</div>

						<!-- Degree -->
						<p class="text-sm text-gray-700 mb-2">
							B.S. in Computer Science
						</p>

						<!-- GPA -->
						<div class="text-sm mb-2">
							<span class="inline-flex items-center gap-1.5 text-gray-600">
								<span class="font-medium text-gray-800">GPA</span>
								3.77&thinsp;/&thinsp;4.0
							</span>
						</div>

						<!-- Core Courses -->
						<div>
							<span class="text-sm font-medium text-gray-800">Core Courses</span>
							<div class="flex flex-wrap gap-1.5 mt-1">
								{['Machine Learning', 'Natural Language Processing', 'Operating Systems', 'Computer Networks', 'Data Structures & Algorithms', 'Computer Organization', 'Database Systems'].map((course) => (
									<span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 border border-gray-200">{course}</span>
								))}
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ── Projects ────────────────────────────────────────── -->
			<section class="mb-12" aria-labelledby="projects-heading">
				<h2 id="projects-heading" class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">Featured Projects</h2>
				<ProjectCards />
			</section>

			<!-- ── More Projects ────────────────────────────────────── -->
			<section class="mb-12" aria-labelledby="more-projects-heading">
				<h2 id="more-projects-heading" class="text-xl font-bold text-gray-900 mb-4 pb-2 border-b border-gray-200">
					More Projects
				</h2>
				<ul class="divide-y divide-gray-100">
					{[
						{
							year: '2025',
							name: 'Distributed DeepSeek Deployment',
							desc: 'A step-by-step guide for distributing DeepSeek LLM inference across Huawei Cloud ECS instances.',
							links: [{ label: 'Code', href: 'https://github.com/KKqdtjo/Distributed_Deployment' }],
						},
						{
							year: '2024',
							name: 'Toutiao Comment Crawler',
							desc: 'Scraped dynamic comment threads from Toutiao by reverse-engineering DOM structure and lazy-loading patterns; preserves hierarchical reply relationships.',
							links: [{ label: 'Code', href: 'https://github.com/KKqdtjo/Toutiao-Crawler-Practice' }],
						},
						{
							year: '2024',
							name: 'Image Captioning System',
							desc: 'Built an image-to-text captioning model from scratch, covering encoder-decoder architecture design, training pipeline, and evaluation.',
							links: [{ label: 'Code', href: 'https://github.com/KKqdtjo/Image_Caption/tree/master' }],
						},
						{
							year: '2024',
							name: 'Surakarta Chess (Online)',
							desc: 'Online multiplayer Surakarta board game developed with Qt, supporting real-time networked play.',
							links: [{ label: 'Code', href: 'https://github.com/KKqdtjo/Surakarta' }],
						},
						{
							year: '2024',
							name: 'Nine Knapsack Problems',
							desc: 'C++ implementations of the classic "Nine Lectures on Knapsack" dynamic-programming variants.',
							links: [{ label: 'Code', href: 'https://github.com/KKqdtjo/Nine_Bags_Problem' }],
						},
					].map((item) => (
						<li class="flex flex-col sm:flex-row sm:items-center gap-x-3 gap-y-0.5 py-3">
							{/* Year */}
							<span class="flex-shrink-0 text-xs font-semibold text-gray-400 w-10">{item.year}</span>

							{/* Name · desc — single truncated line on sm+ */}
							<p class="flex-1 min-w-0 text-sm truncate">
								<span class="font-semibold text-gray-800">{item.name}</span>
								<span class="text-gray-300 mx-1.5" aria-hidden="true">·</span>
								<span class="text-gray-500">{item.desc}</span>
							</p>

							{/* Links */}
							<div class="flex gap-3 flex-shrink-0">
								{item.links.map((link) => (
									<a
										href={link.href}
										target="_blank"
										rel="noopener noreferrer"
										class="inline-flex items-center gap-1 text-xs font-medium text-gray-400 hover:text-gray-900 transition-colors no-underline"
									>
										<svg viewBox="0 0 16 16" aria-hidden="true" width="12" height="12" class="flex-shrink-0">
											<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
										</svg>
										{link.label}
									</a>
								))}
							</div>
						</li>
					))}
				</ul>
			</section>

			<!-- ── Competitions & Awards ─────────────────────────────── -->
			<section class="mb-12" aria-labelledby="awards-heading">
				<h2 id="awards-heading" class="text-xl font-bold text-gray-900 mb-4 pb-2 border-b border-gray-200">
					Competitions &amp; Awards
				</h2>
				<ul class="divide-y divide-gray-100">
					{([
						{
							tier: 'gold',
							title: 'MCM/ICM (Mathematical Contest in Modeling) — Meritorious Winner',
							year: '2025',
							detail: 'American collegiate mathematics modeling competition (Top ~7% worldwide)',
						},
						{
							tier: 'gold',
							title: 'National Undergraduate Mathematical Modeling Contest — 1st Prize (Beijing Region, Group A)',
							year: '2025',
							detail: 'Top prize in Beijing metropolitan division',
						},
						{
							tier: 'gold',
							title: 'Beijing Municipal Innovation & Entrepreneurship Training Program — City-Level Funding',
							year: '2025',
							detail: 'Competitive research grant at city level',
						},
						{
							tier: 'blue',
							title: 'RUC Merit Scholarship (Academic Excellence) — 3rd Prize',
							year: '2025',
							detail: 'Renmin University of China',
						},
						{
							tier: 'gold',
							title: 'Outstanding Communist Youth League Member, RUC',
							year: '2025',
							detail: 'School-level honor',
						},
						{
							tier: 'gold',
							title: 'Three-Good Student (三好学生), RUC',
							year: '2025',
							detail: 'School-level honor',
						},
						{
							tier: 'blue',
							title: 'RUC CS Comprehensive Competition — Computer Networks Track, 3rd Prize',
							year: '2025',
							detail: 'Renmin University of China',
						},
						{
							tier: 'silver',
							title: 'CCF CSP (Software Proficiency Certification) — 300 pts, Top 3.4%',
							year: '2024',
							detail: '40th session; score ranks in the top 3.4% nationally',
						},
						{
							tier: 'silver',
							title: 'RUC Merit Scholarship (Academic Excellence) — 2nd Prize',
							year: '2024',
							detail: 'Renmin University of China',
						},
						{
							tier: 'gold',
							title: 'Programming Contest I (Honor Course) — 1st Prize (Bronze)',
							year: '2023',
							detail: 'Team programming battle, RUC',
						},
					] as { tier: 'gold' | 'silver' | 'blue'; title: string; year: string; detail: string }[]).map((award) => {
						const starColor = award.tier === 'gold' ? '#f59e0b' : award.tier === 'silver' ? '#9ca3af' : '#60a5fa';
						return (
							<li class="flex items-center gap-3 py-2.5">
								<svg aria-hidden="true" class="flex-shrink-0 w-4 h-4" viewBox="0 0 20 20" fill={starColor} xmlns="http://www.w3.org/2000/svg">
									<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
								</svg>
								<div class="flex-1 min-w-0">
									<span class="text-sm font-medium text-gray-800">{award.title}</span>
									<span class="text-xs text-gray-400 ml-2">{award.detail}</span>
								</div>
								<span class="flex-shrink-0 text-xs font-semibold text-gray-400 ml-2">{award.year}</span>
							</li>
						);
					})}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
